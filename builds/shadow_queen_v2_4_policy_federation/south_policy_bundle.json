      "version": 2
    },
    {
      "rule_id": "revoke.clerk.deny",
      "action": "revoke",
      "role": "clerk",
      "allow": true,
      "conditions": {
        "status": [
          "suspended"
        ]
      },
      "reason": "south permits clerk revoke",
      "priority": 100,
      "version": 2
    }
  ]
